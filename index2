        }
        .mobile-menu a:hover { color: #fca5a5; }

        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--bg-base); }
        ::-webkit-scrollbar-thumb { background: var(--border-subtle); border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }
        ::selection { background: rgba(220,38,38,0.3); color: var(--text-primary); }
        :focus:not(:focus-visible) { outline: none; }
        :focus-visible { outline: 2px solid var(--brand-red); outline-offset: 2px; }

        @media (max-width: 768px) {
            .pricing-table thead { display: none; }
            .pricing-table tbody tr {
                display: block; margin-bottom: 0.75rem;
                border: 1px solid var(--border-subtle); border-radius: 0.75rem; overflow: hidden;
            }
            .pricing-table td {
                display: flex; justify-content: space-between; align-items: center;
                padding: 0.75rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.05);
            }
            .pricing-table td:last-child { border-bottom: none; }
            .pricing-table td::before {
                content: attr(data-label); font-weight: 600; color: var(--text-secondary); margin-right: 1rem;
            }
        }

        .counter-value { font-variant-numeric: tabular-nums; }
    </style>
</head>
